# SyncMappings.srv
#
# Called by the Docker/GUI node to push the host's full button and joystick
# mapping database to the robot.  The robot always overwrites its in-memory
# mappings with the received data — no conflict checking, no DB write.

# Request  ─────────────────────────────────────────────────────────────────────
string[] button_names
string[] action_names
string[] trigger_modes
string[] joystick_names
string[] joystick_action_names

---

# Response ─────────────────────────────────────────────────────────────────────
# success:              true if mappings were loaded without error
# loaded_button_count:  number of button mappings loaded
# loaded_joystick_count: number of joystick mappings loaded
# loaded_button_names:  names of buttons that were loaded (for per-item badges)
# loaded_joystick_names: names of joysticks that were loaded (for per-item badges)
bool success
int32 loaded_button_count
int32 loaded_joystick_count
string[] loaded_button_names
string[] loaded_joystick_names
